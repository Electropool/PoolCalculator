{
  "name": "pool-calculator",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "ajv": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.4",
    "react-router-dom": "^6.22.0",
    "react-scripts": "5.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "postbuild": "react-snap",
    "test": "react-scripts test"
  },
  "reactSnap": {
    "source": "build",
    "destination": "build",
    "include": [
      "/",
      "/led-calculator",
      "/resistor-color-code",
      "/smd-code",
      "/capacitor-code",
      "/inductor-code",
      "/about",
      "/contact",
      "/privacy-policy",
      "/terms",
      "/blog",
      "/blog/how-to-read-resistor-color-codes",
      "/blog/what-resistor-for-led",
      "/blog/eia-96-smd-resistor-code-guide"
    ],
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "skipThirdPartyRequests": true,
    "inlineCss": false,
    "saveAs": "html"
  },
  "devDependencies": {
    "react-snap": "^1.23.0"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
